---
import "../../styles/global.css";
import Layout from '../../layouts/Layout.astro'
import propiedades from '../../data/propiedades.json'
import Property from '../../components/Property.jsx'
import Map from '../../components/Map.jsx'

export async function getStaticPaths() {
	const base = [{ params: { filtros: undefined } }]

	const porOperacion = [...new Set(propiedades.map(p => p.operacion))]
		.map(operacion => ({ params: { filtros: operacion } }))

	const porTipo = [...new Set(propiedades.map(p => `${p.operacion}/${p.tipo}`))]
		.map(ruta => ({ params: { filtros: ruta } }))

	return [...base, ...porOperacion, ...porTipo]
}

// Parsear segmentos
const segmentos = Astro.params.filtros?.split('/') ?? []
const [operacion, tipo] = segmentos

// Filtrar
const resultados = propiedades.filter(p => {
	if (operacion && tipo) return p.operacion === operacion && p.tipo === tipo
	if (operacion) return p.operacion === operacion
	return true
})

// SEO dinámico
const titulo = tipo
	? `${tipo} en ${operacion}`
	: operacion
	? `Propiedades en ${operacion}`
	: 'Todas las propiedades'
---

