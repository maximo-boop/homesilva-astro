---
const {item, styles} = Astro.props
---
<li class={`relative menu z-10 ${styles ? 'w-full flex items-center gap-2 lg:gap-4': 'lg:flex'}`}>
	<div class={`flex items-center justify-between gap-2 ${styles ? 'lg:overflow-hidden rounded-[16px] lg:gap-0 bg-white w-full px-6 py-4 lg:p-0 text-nowrap lg:w-fit' : ''}`}>
		<a href={item.url} class={`${styles? 'lg:py-4 lg:px-6 lg:hover:bg-[#fcfcfc] text-lg' : 'hover:text-[#e48957] duration-200 ease'}`}>{item.title}</a>
		<input 
			id={item.title} 
			type="checkbox" 
			class="dropdown-toggle" 
			aria-label={`Abrir submenú de ${item.title}`}
		/>
		<label for={item.title} class={`cursor-pointer w-full lg:w-fit ${styles?'hidden': ''}`} aria-haspopup='true' aria-controls={`submenu-${item.title}`}>
			<span class="sr-only">Abrir submenú de {item.title}</span>
			<svg focusable="false" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" class='ml-auto' width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M6 9l6 6l6 -6" /></svg>
		</label>
	</div>
	<div class={`${styles? 'flex lg:h-full' : 'pt-2 '}`}>
		<ul id={`submenu-${item.title}`} 
			class={`submenu rounded-[16px] ${styles ? 'flex text-nowrap gap-2 py-0 lg:gap-4' : 'lg:shadow-[0_0_10px_rgba(0,0,0,0.05)] lg:absolute top-full left-0 hidden flex-col bg-white text-nowrap py-2 min-w-full'}`}
		>
			{item.childrens.map(c => (
				<li class="flex">
					<a href={c.url} class={`${styles? 'text-lg lg:text-base bg-white text-base py-4 px-6 rounded-[16px] hover:bg-[#fcfcfc]' : 'hover:bg-[#fafafa] text-[16px] py-2 px-4 flex w-full text-start'}`}>{c.title}</a>
				</li>
			))}
		</ul>
	</div>
</li>

<style>

	input {
		pointer-events: none;
		opacity: 0;
		position: absolute;
	}
	.menu:has(input:checked) .submenu,
	.menu:hover .submenu {
		display: flex;
	}

	li {
		list-style: none;
	}

</style>

<script>
	document.addEventListener('click', (e) => {
		const checked = document.querySelector('.dropdown-toggle:checked');
		if (!checked) return;

		document.querySelectorAll('.menu').forEach(menu => {
			if (!menu.contains(e.target)) {
				menu.querySelector('.dropdown-toggle').checked = false;
			}
		});
	});
</script>