<section class="pt-10 px-10 text-center m-auto lg:px-40 flex flex-col gap-2">

	<span class="opacity-[.6] text-2xl">¿Que nós diferencia?</span>
	<h2 class="text-3xl lg:text-4xl">Conocé nuestros servicios inmobiliarios <br> más destacados en Córdoba</h2>

	<ul class="flex gap-10 mt-5 z-10">
		<Carousel client:load data={categories} />
	</ul>

</section>