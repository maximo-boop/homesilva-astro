---
import Carousel from './CarouselThumbnails.jsx';

const categories = [
	{
		label: "Comprador",
		services: [
			{ 
				title: "Búsqueda personalizada de propiedades",
				description: "Te ayudamos a encontrar la propiedad perfecta que se ajuste a tus necesidades y criterios específicos.",
				icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-search"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 10a7 7 0 1 0 14 0a7 7 0 1 0 -14 0" /><path d="M21 21l-6 -6" /></svg>`,
			},
			{ 
				// title: "Asesoría legal", 
				title: "Servicios de negociación",
				description: "Ofrecemos habilidades de negociación para obtener las mejores condiciones en las transacciones de compra o venta de propiedades.",
				icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-contract"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M8 21h-2a3 3 0 0 1 -3 -3v-1h5.5" /><path d="M17 8.5v-3.5a2 2 0 1 1 2 2h-2" /><path d="M19 3h-11a3 3 0 0 0 -3 3v11" /><path d="M9 7h4" /><path d="M9 11h4" /><path d="M18.42 12.61a2.1 2.1 0 0 1 2.97 2.97l-6.39 6.42h-3v-3l6.42 -6.39" /></svg>`,
			},
			{ 
				// title: "Gestión hipotecaria", 
				title: "Asesoramiento en la compra y venta de propiedades",
				description: "Brindamos orientación profesional durante todo el proceso de compra o venta de una propiedad.",
				icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-message-circle-dollar"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M13.16 19.914a9.94 9.94 0 0 1 -5.46 -.914l-4.7 1l1.3 -3.9c-2.324 -3.437 -1.426 -7.872 2.1 -10.374c3.526 -2.501 8.59 -2.296 11.845 .48c1.384 1.181 2.26 2.672 2.603 4.243" /><path d="M21 15h-2.5a1.5 1.5 0 0 0 0 3h1a1.5 1.5 0 0 1 0 3h-2.5" /><path d="M19 21v1m0 -8v1" /></svg>`
			},
		],
	},
	{
		label: "Vendedor",
		services: [
			{ 
				// title: "Tasación profesional", 
				title: "Evaluación y tasación de propiedades en Córdoba Capital",
				description: "Ofrecemos evaluación y tasación de propiedades para determinar el valor justo de una propiedad o para tener una idea realista del precio de compra.",
				icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-chart-histogram"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 3v18h18" /><path d="M20 18v3" /><path d="M16 16v5" /><path d="M12 13v8" /><path d="M8 16v5" /><path d="M3 11c6 0 5 -5 9 -5s3 5 9 5" /></svg>`
			},
			{ 
				// title: "Marketing inmobiliario", 
				title: "Asistencia en trámites legales y financieros",
				description: "Te proporcionamos asistencia en los trámites legales y financieros para que la compra o venta de tu propiedad sea fácil y sin complicaciones.",
				icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-scale"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M7 20l10 0" /><path d="M6 6l6 -1l6 1" /><path d="M12 3l0 17" /><path d="M9 12l-3 -6l-3 6a3 3 0 0 0 6 0" /><path d="M21 12l-3 -6l-3 6a3 3 0 0 0 6 0" /></svg>`
			},
			{ 
				// title: "Gestión de visitas",
				title: "Gestión de visitas y exhibiciones de propiedades",
				description: "Realizamos visitas a las propiedades para que puedas conocerlas en persona y tomar decisiones informadas.",
				icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-door"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M14 12v.01" /><path d="M3 21h18" /><path d="M6 21v-16a2 2 0 0 1 2 -2h8a2 2 0 0 1 2 2v16" /></svg>`
			},
			// Si deseas mejorar el aspecto y el valor de una propiedad, ofrecemos servicios de diseño de interiores y remodelación.
		],
	},
];
// 1. Resalta que no solo tenes un catalogo de propiedades, sino que te dedicas a encontrar 
// 1. el hogar perfecto segun ls necesiades del cliente
// 3. Menciona si trabajas con bancos o si pueden orientarlos para conseguir un credito
// 3. hipotecario. esto genera confianza
// 4. Explica brevemente como realisas la tasacion (analisis del mercado, experiencia, etc.)
//  6. Acompañamiento en el proceso de compra. desde las visitas hasta la firma
//  6. de la escritura, es el servicio que garantiza tranquilidad
// asesoria para compradores , analisis del mercado: si te enfocas en inversores, ayudarlos a identificar 
// las zonas con mayor potencial de crecimiento y rentabilidad.
---

<section class="global-padding text-center m-auto flex flex-col max-w-[1400px] mx-auto gap-2">

	<p class="text-[#888] text-lg lg:text-xl">¿Por qué elegirnos?</p>
	<h2 class="text-xl lg:text-3xl">Conocé nuestros servicios inmobiliarios <br class="hidden lg:inline"> más destacados en Córdoba</h2>

	<div class="flex gap-10 mt-5 z-10">
		<Carousel client:visible data={categories} />
	</div>

</section>