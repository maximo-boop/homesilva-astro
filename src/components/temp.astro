---
import "../../styles/global.css";
import Layout from '../../layouts/Layout.astro'
import propiedades from '../../data/propiedades.json'
import PropertiesFilters from '@/components/PropertiesFilters.jsx'
import {toSlug, toPlural, toSingular } from '@/utils/utils.js'

export function parsearFiltros(filtrosParam) {
	const OPERACIONES = propiedades.map(p => p.operacion.toLowerCase())
	const TIPOS = propiedades.map(p => toPlural(p.tipo.toLowerCase()))
	const segmentos = filtrosParam?.split('/').filter(Boolean) ?? []

	return {
		operacion: segmentos.find(s => OPERACIONES.includes(s)) ?? null,
		tipo: segmentos.find(s => TIPOS.includes(s)) ?? null,
		localidad: segmentos.find(s => !OPERACIONES.includes(s) && !TIPOS.includes(s)) ?? null,
	}
}

export async function getStaticPaths() {
	const localidades = [...new Set(propiedades.map(p => toSlug(p.localidad)))]
	const tipos = [...new Set(propiedades.map(p => toPlural(p.tipo.toLowerCase())))]
	const operaciones = [...new Set(propiedades.map(p => p.operacion.toLowerCase()))]

	const paths = new Set()
	paths.add(undefined)

	operaciones.forEach(o => paths.add(o))
	tipos.forEach(t => paths.add(t))
	localidades.forEach(l => paths.add(l))

	operaciones.forEach(o => {
		tipos.forEach(t => paths.add(`${o}/${t}`))
		localidades.forEach(l => paths.add(`${o}/${l}`))
	})
	tipos.forEach(t => {
		localidades.forEach(l => paths.add(`${t}/${l}`))
	})
	operaciones.forEach(o => {
		tipos.forEach(t => {
			localidades.forEach(l => paths.add(`${o}/${t}/${l}`))
		})
	})

	return [...paths].map(filtros => ({ params: { filtros } }))
}

const { operacion, tipo, localidad } = parsearFiltros(Astro.params.filtros)
const resultados = propiedades.filter(p => {
	if (operacion && p.operacion.toLowerCase() !== operacion) return false
	if (tipo && p.tipo.toLowerCase() !== toSingular(tipo)) return false
	if (localidad && toSlug(p.localidad) !== localidad) return false
	return true
})

const localidadDisplay = localidad ? resultados[0]?.localidad : null
const partes = [
	tipo ? tipo.charAt(0).toUpperCase() + tipo.slice(1) : 'Propiedades',
	operacion ? `en ${operacion}` : null,
	localidadDisplay ? `- ${localidadDisplay}` : null,
].filter(Boolean)
const titulo = partes.join(' ')

